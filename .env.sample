# ── API ──────────────────────────────────────────────────────────────────────
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MODEL_NAME=kimi-k2.5

# ── 项目配置 ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_RETRIES=3
REQUEST_TIMEOUT=30

# ── Agent 提示词（留空则使用代码内默认值）────────────────────────────────────────
# interviewee_agent 使用的 Jinja2 模板文件路径
INTERVIEWEE_PROMPT_TEMPLATE=
# life_generator 使用的系统提示词文件路径
LIFE_GENERATOR_SYSTEM_PROMPT=
# interviewer_agent 使用的系统提示词文件路径
INTERVIEWER_SYSTEM_PROMPT=prompts/interviewer_system_prompt.txt
